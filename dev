#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$ROOT_DIR/backend"
FRONTEND_DIR="$ROOT_DIR/frontend"

BACKEND_PID_FILE="/tmp/skyway-backend.pid"
FRONTEND_PID_FILE="/tmp/skyway-frontend.pid"
BACKEND_LOG="/tmp/skyway-backend.log"
FRONTEND_LOG="/tmp/skyway-frontend.log"

# Bind host for development servers. Use BIND_HOST=0.0.0.0 for LAN access.
BIND_HOST="${BIND_HOST:-127.0.0.1}"
BACKEND_URL="http://127.0.0.1:8000/api/filters/"
FRONTEND_URL="http://127.0.0.1:3000"

usage() {
  cat <<'EOF'
Usage: ./dev <command>

Commands:
  setup   Install dependencies and create local env files if missing
  up      Start backend and frontend in the background
  refresh Reset stale local state, restart services, then run doctor
  down    Stop backend and frontend
  status  Show whether services are running
  doctor  Run local diagnostics for common startup/runtime issues
  logs    Tail backend and frontend logs
EOF
}

print_header() {
  echo
  echo "== $1 =="
}

pid_is_running() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

read_pid() {
  local file="$1"
  if [[ -f "$file" ]]; then
    cat "$file"
  fi
}

port_listener_pid() {
  local port="$1"
  lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | head -n 1 || true
}

pid_cmdline() {
  local pid="$1"
  ps -p "$pid" -o command= 2>/dev/null || true
}

pid_matches_pattern() {
  local pid="$1"
  local expected_pattern="$2"
  local cmdline
  cmdline="$(pid_cmdline "$pid")"
  [[ "$cmdline" == *"$expected_pattern"* || "$cmdline" == *"next-server"* ]]
}

clear_stale_listener() {
  local name="$1"
  local port="$2"
  local pid_file="$3"
  local expected_pattern="$4"

  local tracked_pid listener_pid cmdline
  tracked_pid="$(read_pid "$pid_file" || true)"
  listener_pid="$(port_listener_pid "$port")"

  if [[ -z "$listener_pid" ]]; then
    return 0
  fi

  if [[ -n "$tracked_pid" && "$listener_pid" == "$tracked_pid" ]] && pid_is_running "$tracked_pid"; then
    return 0
  fi

  cmdline="$(pid_cmdline "$listener_pid")"
  if [[ "$cmdline" == *"$expected_pattern"* || "$cmdline" == *"next-server"* ]]; then
    echo "Found stale ${name} listener on :${port} (pid ${listener_pid}); stopping it"
    kill "$listener_pid" 2>/dev/null || true
    for _ in $(seq 1 10); do
      if ! pid_is_running "$listener_pid"; then
        break
      fi
      sleep 1
    done
    if pid_is_running "$listener_pid"; then
      kill -9 "$listener_pid" 2>/dev/null || true
    fi
    return 0
  fi

  echo "${name} port ${port} is in use by pid ${listener_pid}: ${cmdline}"
  echo "Stop that process and rerun ./dev up"
  return 1
}

ensure_backend_env() {
  if [[ ! -f "$BACKEND_DIR/.env" && -f "$BACKEND_DIR/.env.example" ]]; then
    cp "$BACKEND_DIR/.env.example" "$BACKEND_DIR/.env"
    echo "Created backend/.env from .env.example"
  fi
}

ensure_frontend_env() {
  if [[ ! -f "$FRONTEND_DIR/.env.local" && -f "$FRONTEND_DIR/.env.local.example" ]]; then
    cp "$FRONTEND_DIR/.env.local.example" "$FRONTEND_DIR/.env.local"
    echo "Created frontend/.env.local from .env.local.example"
  fi
}

setup_backend() {
  print_header "Backend setup"
  if [[ ! -x "$BACKEND_DIR/.venv/bin/python" ]]; then
    (cd "$BACKEND_DIR" && python3 -m venv .venv)
    echo "Created backend virtualenv"
    (
      cd "$BACKEND_DIR"
      source .venv/bin/activate
      pip install -r requirements.txt
    )
  else
    echo "Backend virtualenv already exists; skipping pip install"
  fi

  ensure_backend_env
}

setup_frontend() {
  print_header "Frontend setup"
  if [[ ! -d "$FRONTEND_DIR/node_modules" ]]; then
    (cd "$FRONTEND_DIR" && npm install)
  else
    echo "frontend/node_modules already exists; skipping npm install"
  fi
  ensure_frontend_env
}

setup_all() {
  setup_backend
  setup_frontend
  print_header "Setup complete"
}

wait_for_url() {
  local name="$1"
  local url="$2"
  local seconds="${3:-20}"

  for _ in $(seq 1 "$seconds"); do
    if curl -fsS "$url" >/dev/null 2>&1; then
      echo "$name is responding at $url"
      return 0
    fi
    sleep 1
  done

  echo "$name did not become healthy in ${seconds}s: $url"
  return 1
}

frontend_http_code() {
  curl -sS -o /dev/null -w '%{http_code}' --connect-timeout 3 --max-time 8 "$FRONTEND_URL" || true
}

frontend_missing_chunk_error_present() {
  if [[ ! -f "$FRONTEND_LOG" ]]; then
    return 1
  fi
  tail -n 200 "$FRONTEND_LOG" | grep -Eq "Cannot find module '\./[0-9]+\.js'"
}

start_detached() {
  local command="$1"
  local log_file="$2"
  local pid_file="$3"

  if command -v setsid >/dev/null 2>&1; then
    nohup setsid /bin/bash -lc "$command" < /dev/null >"$log_file" 2>&1 &
  else
    nohup /bin/bash -lc "$command" < /dev/null >"$log_file" 2>&1 &
  fi
  echo "$!" >"$pid_file"
}

start_frontend_process() {
  start_detached "cd \"$FRONTEND_DIR\" && exec npm run dev -- -H ${BIND_HOST} -p 3000" "$FRONTEND_LOG" "$FRONTEND_PID_FILE"
}

restart_frontend_clean() {
  print_header "Frontend auto-recovery"
  stop_service "Frontend" "$FRONTEND_PID_FILE" 3000 "next"
  clear_stale_listener "Frontend" 3000 "$FRONTEND_PID_FILE" "next"
  reset_frontend_cache
  start_frontend_process
}

start_backend() {
  print_header "Starting backend"
  clear_stale_listener "Backend" 8000 "$BACKEND_PID_FILE" "manage.py runserver"
  local pid
  pid="$(read_pid "$BACKEND_PID_FILE" || true)"
  if pid_is_running "$pid"; then
    echo "Backend already running (pid $pid)"
    return 0
  fi

  ensure_backend_env

  if ! (
    cd "$BACKEND_DIR"
    source .venv/bin/activate
    python manage.py migrate --noinput
  ); then
    echo "Backend migration failed. Ensure PostgreSQL is running and backend/.env is correct."
    return 1
  fi

  start_detached "cd \"$BACKEND_DIR\" && source .venv/bin/activate && exec python manage.py runserver ${BIND_HOST}:8000" "$BACKEND_LOG" "$BACKEND_PID_FILE"

  if ! wait_for_url "Backend" "$BACKEND_URL" 25; then
    echo "Last backend log lines:"
    tail -n 40 "$BACKEND_LOG" || true
    return 1
  fi
  sync_pid_file_with_listener "Backend" 8000 "$BACKEND_PID_FILE" || true
}

start_frontend() {
  print_header "Starting frontend"
  clear_stale_listener "Frontend" 3000 "$FRONTEND_PID_FILE" "next dev"
  local pid
  pid="$(read_pid "$FRONTEND_PID_FILE" || true)"
  if pid_is_running "$pid"; then
    local existing_code
    existing_code="$(frontend_http_code)"
    if [[ "$existing_code" == "200" ]]; then
      echo "Frontend already running (pid $pid)"
      return 0
    fi

    if frontend_missing_chunk_error_present; then
      echo "Frontend running (pid $pid) but missing chunk error detected; attempting auto-recovery"
      restart_frontend_clean
      if wait_for_url "Frontend" "$FRONTEND_URL" 30; then
        sync_pid_file_with_listener "Frontend" 3000 "$FRONTEND_PID_FILE" || true
        return 0
      fi
      echo "Last frontend log lines:"
      tail -n 60 "$FRONTEND_LOG" || true
      return 1
    fi

    echo "Frontend process running (pid $pid) but unhealthy (HTTP ${existing_code}); restart with ./dev refresh"
    tail -n 40 "$FRONTEND_LOG" || true
    return 1
  fi

  local listener_pid
  listener_pid="$(port_listener_pid 3000)"
  if [[ -n "$listener_pid" && "$listener_pid" != "$pid" ]]; then
    if frontend_missing_chunk_error_present; then
      echo "Missing chunk error detected with a stale listener; forcing clean restart"
      restart_frontend_clean
      if wait_for_url "Frontend" "$FRONTEND_URL" 30; then
        sync_pid_file_with_listener "Frontend" 3000 "$FRONTEND_PID_FILE" || true
        return 0
      fi
      echo "Last frontend log lines:"
      tail -n 60 "$FRONTEND_LOG" || true
      return 1
    fi
  fi

  ensure_frontend_env

  start_frontend_process

  if wait_for_url "Frontend" "$FRONTEND_URL" 25; then
    sync_pid_file_with_listener "Frontend" 3000 "$FRONTEND_PID_FILE" || true
    return 0
  fi

  if frontend_missing_chunk_error_present; then
    echo "Frontend startup failed with missing chunk error; attempting clean auto-recovery"
    restart_frontend_clean
    if wait_for_url "Frontend" "$FRONTEND_URL" 30; then
      sync_pid_file_with_listener "Frontend" 3000 "$FRONTEND_PID_FILE" || true
      return 0
    fi
    echo "Last frontend log lines:"
    tail -n 60 "$FRONTEND_LOG" || true
    return 1
  fi

  echo "Last frontend log lines:"
  tail -n 40 "$FRONTEND_LOG" || true
  return 1
}

stop_service() {
  local name="$1"
  local pid_file="$2"
  local port="$3"
  local expected_pattern="$4"
  local pid
  pid="$(read_pid "$pid_file" || true)"
  local listener_pid
  listener_pid="$(port_listener_pid "$port")"

  if pid_is_running "$pid"; then
    kill "$pid" 2>/dev/null || true
    for _ in $(seq 1 10); do
      if ! pid_is_running "$pid"; then
        break
      fi
      sleep 1
    done
    if pid_is_running "$pid"; then
      kill -9 "$pid" 2>/dev/null || true
    fi
  fi

  listener_pid="$(port_listener_pid "$port")"
  if [[ -n "$listener_pid" ]] && pid_is_running "$listener_pid"; then
    if pid_matches_pattern "$listener_pid" "$expected_pattern"; then
      kill "$listener_pid" 2>/dev/null || true
      for _ in $(seq 1 10); do
        if ! pid_is_running "$listener_pid"; then
          break
        fi
        sleep 1
      done
      if pid_is_running "$listener_pid"; then
        kill -9 "$listener_pid" 2>/dev/null || true
      fi
    else
      echo "$name listener on :${port} belongs to another process; not stopping it"
      echo "Process: $(pid_cmdline "$listener_pid")"
      return 1
    fi
  fi

  rm -f "$pid_file"
  echo "$name stopped"
}

sync_pid_file_with_listener() {
  local name="$1"
  local port="$2"
  local pid_file="$3"
  local listener_pid
  listener_pid="$(port_listener_pid "$port")"
  if [[ -n "$listener_pid" ]]; then
    echo "$listener_pid" >"$pid_file"
    return 0
  fi
  echo "Could not determine ${name} listener PID on :${port}"
  return 1
}

status_all() {
  print_header "Service status"
  local backend_pid frontend_pid backend_listener frontend_listener
  backend_pid="$(read_pid "$BACKEND_PID_FILE" || true)"
  frontend_pid="$(read_pid "$FRONTEND_PID_FILE" || true)"
  backend_listener="$(port_listener_pid 8000)"
  frontend_listener="$(port_listener_pid 3000)"

  if [[ -n "$backend_listener" ]] && pid_is_running "$backend_listener"; then
    echo "Backend: running (pid $backend_listener) -> http://${BIND_HOST}:8000"
  else
    echo "Backend: stopped"
  fi

  if [[ -n "$frontend_listener" ]] && pid_is_running "$frontend_listener"; then
    echo "Frontend: running (pid $frontend_listener) -> http://${BIND_HOST}:3000"
  else
    echo "Frontend: stopped"
  fi

  if [[ -n "$backend_listener" && "$backend_listener" != "$backend_pid" ]]; then
    echo "$backend_listener" >"$BACKEND_PID_FILE"
  fi
  if [[ -n "$frontend_listener" && "$frontend_listener" != "$frontend_pid" ]]; then
    echo "$frontend_listener" >"$FRONTEND_PID_FILE"
  fi

  echo "Logs: $BACKEND_LOG and $FRONTEND_LOG"
}

logs_all() {
  print_header "Tailing logs"
  touch "$BACKEND_LOG" "$FRONTEND_LOG"
  tail -n 120 -f "$BACKEND_LOG" "$FRONTEND_LOG"
}

reset_frontend_cache() {
  if [[ -d "$FRONTEND_DIR/.next" ]]; then
    rm -rf "$FRONTEND_DIR/.next"
    echo "Removed frontend/.next cache"
  fi
}

refresh_all() {
  print_header "Refreshing local services"
  down_all
  clear_stale_listener "Frontend" 3000 "$FRONTEND_PID_FILE" "next"
  clear_stale_listener "Backend" 8000 "$BACKEND_PID_FILE" "manage.py runserver"
  rm -f "$FRONTEND_PID_FILE" "$BACKEND_PID_FILE"
  reset_frontend_cache
  up_all
  doctor_all
}

doctor_required_key() {
  local file="$1"
  local key="$2"
  if [[ ! -f "$file" ]]; then
    echo "missing-file"
    return
  fi
  # Use grep here (not rg) so this works even when ripgrep isn't on PATH.
  # Accept optional Windows CRLF at end of line.
  if grep -Eq "^${key}=.*\r?$" "$file"; then
    echo "ok"
  else
    echo "missing-key"
  fi
}

doctor_all() {
  print_header "Doctor"

  local fail_count=0
  local warn_count=0

  ok() { echo "[OK] $*"; }
  warn() {
    echo "[WARN] $*"
    warn_count=$((warn_count + 1))
  }
  fail() {
    echo "[FAIL] $*"
    fail_count=$((fail_count + 1))
  }

  if command -v node >/dev/null 2>&1; then ok "node: $(node -v)"; else fail "node not found"; fi
  if command -v npm >/dev/null 2>&1; then ok "npm: $(npm -v)"; else fail "npm not found"; fi
  if command -v python3 >/dev/null 2>&1; then ok "python3: $(python3 --version 2>&1)"; else fail "python3 not found"; fi
  if command -v curl >/dev/null 2>&1; then ok "curl is available"; else fail "curl not found"; fi
  if command -v lsof >/dev/null 2>&1; then ok "lsof is available"; else warn "lsof not found; port diagnostics limited"; fi

  if [[ -d "$BACKEND_DIR/.venv" ]]; then ok "backend/.venv exists"; else fail "backend/.venv missing (run ./dev setup)"; fi
  if [[ -d "$FRONTEND_DIR/node_modules" ]]; then ok "frontend/node_modules exists"; else fail "frontend/node_modules missing (run ./dev setup)"; fi

  case "$(doctor_required_key "$BACKEND_DIR/.env" POSTGRES_HOST)" in
    ok) ok "backend/.env present with POSTGRES_HOST" ;;
    missing-key) fail "backend/.env missing POSTGRES_HOST" ;;
    *) fail "backend/.env missing (run ./dev setup)" ;;
  esac
  case "$(doctor_required_key "$BACKEND_DIR/.env" POSTGRES_DB)" in
    ok) ok "backend/.env includes POSTGRES_DB" ;;
    *) fail "backend/.env missing POSTGRES_DB" ;;
  esac
  case "$(doctor_required_key "$FRONTEND_DIR/.env.local" NEXT_PUBLIC_API_BASE_URL)" in
    ok) ok "frontend/.env.local present with NEXT_PUBLIC_API_BASE_URL" ;;
    missing-key) fail "frontend/.env.local missing NEXT_PUBLIC_API_BASE_URL" ;;
    *) fail "frontend/.env.local missing (run ./dev setup)" ;;
  esac

  local db_listener
  db_listener="$(port_listener_pid 5432)"
  if [[ -n "$db_listener" ]]; then
    ok "PostgreSQL listener detected on :5432 (pid $db_listener)"
  else
    warn "No listener on :5432; ensure PostgreSQL is running"
  fi

  local backend_listener frontend_listener
  backend_listener="$(port_listener_pid 8000)"
  frontend_listener="$(port_listener_pid 3000)"
  if [[ -n "$backend_listener" ]]; then
    ok "Backend listener detected on :8000 (pid $backend_listener)"
  else
    warn "No listener on :8000"
  fi
  if [[ -n "$frontend_listener" ]]; then
    ok "Frontend listener detected on :3000 (pid $frontend_listener)"
  else
    warn "No listener on :3000"
  fi

  local api_code frontend_code
  api_code="$(curl -sS -o /dev/null -w '%{http_code}' --connect-timeout 3 --max-time 8 "$BACKEND_URL" || true)"
  if [[ "$api_code" == "200" ]]; then
    ok "Backend API healthy at $BACKEND_URL"
  else
    fail "Backend API returned $api_code at $BACKEND_URL"
  fi

  frontend_code="$(curl -sS -o /dev/null -w '%{http_code}' --connect-timeout 3 --max-time 8 "$FRONTEND_URL" || true)"
  if [[ "$frontend_code" == "200" ]]; then
    ok "Frontend healthy at $FRONTEND_URL"
  else
    fail "Frontend returned $frontend_code at $FRONTEND_URL"
  fi

  if [[ -x "$BACKEND_DIR/.venv/bin/python" ]]; then
    if (
      cd "$BACKEND_DIR"
      source .venv/bin/activate
      python manage.py shell -c "from django.db import connection; c=connection.cursor(); c.execute('select 1'); print(c.fetchone()[0])" \
        | grep -qx "1"
    ); then
      ok "Database connectivity from Django verified"
    else
      fail "Django database connectivity check failed"
    fi
  fi

  if [[ "$frontend_code" == "200" ]]; then
    local tmp_html tmp_asset_list
    tmp_html="$(mktemp /tmp/skyway-doctor-home.XXXXXX)"
    tmp_asset_list="$(mktemp /tmp/skyway-doctor-assets.XXXXXX)"
    curl -sS "$FRONTEND_URL" >"$tmp_html" || true
    grep -Eo '/_next/static/[^" ]+' "$tmp_html" | sort -u >"$tmp_asset_list" || true

    local total_assets bad_assets
    total_assets="$(wc -l <"$tmp_asset_list" | tr -d ' ')"
    bad_assets=0
    if [[ "$total_assets" -gt 0 ]]; then
      while IFS= read -r asset; do
        [[ -z "$asset" ]] && continue
        local code
        code="$(curl -sS -o /dev/null -w '%{http_code}' --connect-timeout 3 --max-time 8 "${FRONTEND_URL}${asset#${FRONTEND_URL}}" || true)"
        if [[ "$code" != "200" ]]; then
          bad_assets=$((bad_assets + 1))
        fi
      done <"$tmp_asset_list"

      if [[ "$bad_assets" -eq 0 ]]; then
        ok "Frontend static asset sanity check passed (${total_assets} assets)"
      else
        fail "Frontend static asset sanity failed (${bad_assets}/${total_assets} non-200)"
      fi
    else
      warn "No _next static assets found in homepage HTML"
    fi
  fi

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    if [[ -n "$(git status --porcelain)" ]]; then
      warn "Git worktree has uncommitted changes"
    else
      ok "Git worktree clean"
    fi
  fi

  echo
  if [[ "$fail_count" -gt 0 ]]; then
    echo "Doctor found ${fail_count} failure(s) and ${warn_count} warning(s)"
    return 1
  fi
  echo "Doctor passed with ${warn_count} warning(s)"
}

up_all() {
  setup_all
  start_backend
  start_frontend
  print_header "Ready"
  echo "Backend:  http://${BIND_HOST}:8000/api"
  echo "Frontend: http://${BIND_HOST}:3000"
}

down_all() {
  print_header "Stopping services"
  stop_service "Frontend" "$FRONTEND_PID_FILE" 3000 "next"
  stop_service "Backend" "$BACKEND_PID_FILE" 8000 "manage.py runserver"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    setup) setup_all ;;
    up) up_all ;;
    refresh) refresh_all ;;
    down) down_all ;;
    status) status_all ;;
    doctor) doctor_all ;;
    logs) logs_all ;;
    *) usage; exit 1 ;;
  esac
}

main "${1:-}"
