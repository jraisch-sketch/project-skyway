# Copy to scripts/db_sync.env and fill real values.
# This file is intentionally separate from backend/.env because it includes
# multiple environment credentials for snapshot copy workflows.

# Production source DB (required)
PROD_DB_HOST=
PROD_DB_PORT=5432
PROD_DB_NAME=
PROD_DB_USER=
PROD_DB_PASSWORD=

# Staging target DB (required for snapshot-to-staging / restore-to-staging)
STAGING_DB_HOST=
STAGING_DB_PORT=5432
STAGING_DB_NAME=
STAGING_DB_USER=
STAGING_DB_PASSWORD=

# Local target DB (optional if backend/.env has POSTGRES_* values)
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=skyway
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres

# Optional overrides
# ENV_FILE=/absolute/path/to/db_sync.env
# SNAPSHOT_DIR=/absolute/path/to/snapshots/db
